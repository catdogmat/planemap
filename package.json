{
  "name": "planemap",
  "author": "CasCasey",
  "version": "1.6",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "dependencies": {
    "@rebble/clay": "^1.0.8"
  },
  "pebble": {
    "displayName": "Plane Map",
    "uuid": "3a375aaa-91b1-4dc3-8430-b87c1255843b",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "capabilities": [
      "configurable"
    ],
    "targetPlatforms": [
      "aplite",
      "basalt",
      "diorite",
      "flint"
