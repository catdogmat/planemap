      "PLANES_DATA",
      "KEY_ZOOM_IN",
      "KEY_ZOOM_OUT",
      "KEY_CURRENT_RADIUS",
      "KEY_IS_METRIC",
      "UNITS_METRIC",
      "KEY_ROTATE_MAP",
      "ROTATE_MAP",
      "OVERRIDE_LOCATION",
      "MANUAL_LAT",
      "MANUAL_LON",
      "KEY_REQUEST_ROUTE",
      "ROUTE_DATA",
      "MAX_PLANES"
    ],
    "resources": {
      "media": [
        {
          "type": "bitmap",
          "name": "MENU_ICON",
          "file": "images/plane.png",
          "menuIcon": true
        }
      ]
    }
  }
}


